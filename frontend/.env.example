# Copy this file to .env.local for local development
# In production (Vercel), set VITE_API_URL in Project Settings → Environment Variables

# Local development (default — no need to set this)
# VITE_API_URL=http://127.0.0.1:8000

# Production — replace with your actual Render.com backend URL
# VITE_API_URL=https://aura-actuarial-backend.onrender.com
